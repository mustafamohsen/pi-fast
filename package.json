{
  "name": "@mustafamohsen/pi-fast",
  "version": "0.1.0-alpha.2",
  "description": "Pi extension for OpenAI Codex Fast mode controls via /fast on|off|status.",
  "type": "module",
  "license": "MIT",
  "author": "Mustafa Mohsen",
  "homepage": "https://github.com/mustafamohsen/pi-fast#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mustafamohsen/pi-fast.git"
  },
  "bugs": {
    "url": "https://github.com/mustafamohsen/pi-fast/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "codex",
    "fast-mode",
    "openai-codex"
  ],
  "files": [
    "extensions/",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "pi": {
    "extensions": [
      "./extensions/fast-mode.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "bun run biome:check && bun run typecheck && bun test",
    "pack:dry-run": "bun pm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --tag alpha",
    "publish:alpha": "npm publish --tag alpha",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "benchmark:e2e": "bun scripts/e2e-speed-benchmark.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
